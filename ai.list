# ==========================================
# 优化版 AI 专属分流规则 (AI.list)
# ==========================================

# 1. OpenAI (ChatGPT / Sora / API)
DOMAIN-KEYWORD,openai
DOMAIN-SUFFIX,chatgpt.com
DOMAIN-SUFFIX,oaistatic.com
DOMAIN-SUFFIX,oaiusercontent.com
DOMAIN-SUFFIX,openai.com
DOMAIN-SUFFIX,openaiapi-site.azureedge.net
DOMAIN-SUFFIX,sora.com

# 2. Anthropic (Claude)
DOMAIN-KEYWORD,anthropic
DOMAIN-KEYWORD,claude
DOMAIN-SUFFIX,anthropic.com
DOMAIN-SUFFIX,claude.ai
DOMAIN-SUFFIX,claude.com
DOMAIN-SUFFIX,claudeusercontent.com

# 3. Google (Gemini / AI Studio / NotebookLM)
# 使用精确 DOMAIN 匹配，避免 DOMAIN-KEYWORD,gemini 撕裂 google.com 流量
DOMAIN,gemini.google.com
DOMAIN,aistudio.google.com
DOMAIN,ai.google.dev
DOMAIN,generativelanguage.googleapis.com
DOMAIN,notebooklm.google.com
DOMAIN-SUFFIX,notebooklm.google
DOMAIN-SUFFIX,makersuite.google.com
DOMAIN-SUFFIX,bard.google.com

# 4. Microsoft (Copilot)
DOMAIN,api.githubcopilot.com
DOMAIN,copilot-proxy.githubusercontent.com
DOMAIN,sydney.bing.com
DOMAIN-SUFFIX,copilot.cloud.microsoft
DOMAIN-SUFFIX,copilot.microsoft.com

